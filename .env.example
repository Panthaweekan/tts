# Twitch Bot Credentials
BOT_USERNAME=your_bot_username
OAUTH_TOKEN=oauth:your_oauth_token
CHANNEL=your_channel_name

# TTS Settings (Neural AI)
# Available voices:
#   Thai:  th-TH-PremwadeeNeural (Female), th-TH-NiwatNeural (Male)
#   Multi: en-US-EmmaMultilingualNeural (Female), en-US-AndrewMultilingualNeural (Male)
TTS_VOICE=th-TH-PremwadeeNeural

# Volume: -100% to +0% (Recommended: -95% for quiet background)
TTS_VOLUME=-95%

# Username Shortening: Max characters to read from name
NAME_MAX_LENGTH=6

# Session Caching: Skip reading username if same user speaks within this window (ms)
SESSION_WINDOW_MS=30000

# Anti-Spam / Cooldowns (ms)
COOLDOWN_GLOBAL_MS=2000
COOLDOWN_USER_MS=8000
