{
  "name": "tts",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "bun index.ts",
    "go": "bun launcher.ts",
    "auth": "bun launcher.ts --auth",
    "build": "bun build --compile --windows-icon=XantaTTS.ico --outfile=XantaTTS.exe ./launcher.ts",
    "test": "bun test",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "precommit": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "release": "git tag v$(node -p \"require('./package.json').version\") && git push origin --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Panthaweekan/tts.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Panthaweekan/tts/issues"
  },
  "homepage": "https://github.com/Panthaweekan/tts#readme",
  "dependencies": {
    "edge-tts-universal": "^1.4.0",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/tmi.js": "^1.8.6",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
